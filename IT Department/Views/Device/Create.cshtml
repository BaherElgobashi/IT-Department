@model IT.BLL.ViewModels.DeviceViewModel

@{
    ViewBag.Title = "Add New Device";
    var categories = ViewBag.Categories as List<IT.DAL.Entities.DeviceCategory>;
}

<h2>Add New Device</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="AcquisitionDate"></label>
        <input asp-for="AcquisitionDate" type="date" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Memo"></label>
        <textarea asp-for="Memo" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label for="DeviceCategoryId">Device Category</label>
        <select asp-for="DeviceCategoryId" class="form-control" id="DeviceCategoryId">
            <option value="">-- Select Category --</option>
            @foreach (var cat in categories)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
    </div>

    <div id="dynamicProperties"></div>

    <button type="submit" class="btn btn-primary mt-3">Add Device</button>
</form>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $('#DeviceCategoryId').on('change', function () {
        var categoryId = $(this).val();
        if (categoryId) {
        $.ajax({
        url: '/Device/GetPropertiesByCategoryId',
        type: 'GET',
        data: { categoryId: categoryId },
        success: function (data) {
        var html = '';
        for (var i = 0; i < data.length; i++) {
        html += `
        <div class="form-group">
        <label>${data[i].description}</label>
        <input name="PropertyValues[${data[i].id}]" class="form-control" />
        </div>`;
        }
        $('#dynamicProperties').html(html);
        }
        });
        } else {
        $('#dynamicProperties').html('');
        }
        });
    </script>
}
