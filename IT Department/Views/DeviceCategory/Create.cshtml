@model IT.BLL.ViewModels.DeviceCategoryViewModel

<h2>Add Device Category</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Select Properties</label>
        @foreach (var prop in Model.AllProperties)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox"
                       name="SelectedPropertyIds" value="@prop.Id" id="prop_@prop.Id" />
                <label class="form-check-label" for="prop_@prop.Id">@prop.Description</label>
            </div>
        }
        <span asp-validation-for="SelectedPropertyIds" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Add Category</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
