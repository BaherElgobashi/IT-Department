@model IT.DAL.Entities.DeviceCategory

<h2>Delete Category</h2>

<div class="alert alert-warning">Are you sure you want to delete this category?</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <div><strong>@Model.Name</strong></div>
    <button type="submit" class="btn btn-danger mt-2">Delete</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Cancel</a>
</form>
