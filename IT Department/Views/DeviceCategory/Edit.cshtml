@model IT.BLL.ViewModels.DeviceCategoryViewModel

@{
    ViewBag.Title = "Edit Category";
    int categoryId = ViewBag.CategoryId;
}

<h2>Edit Category</h2>

<form asp-action="Edit" asp-route-id="@categoryId" method="post">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Update Properties</label>
        @foreach (var prop in Model.AllProperties)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox"
                       name="SelectedPropertyIds"
                       value="@prop.Id"
                       id="prop_@prop.Id"
                @(Model.SelectedPropertyIds.Contains(prop.Id) ? "checked" : "") />
                <label class="form-check-label" for="prop_@prop.Id">@prop.Description</label>
            </div>
        }
        <span asp-validation-for="SelectedPropertyIds" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-2">Update Category</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
